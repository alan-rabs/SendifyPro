# Sendify PRO - Environment Variables Example

# GEMINI_API_KEY: Required for Gemini AI API calls (if used).
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL=""

# AUTOSTART_BOT: If set to 'true', the bot will start automatically when the server starts.
AUTOSTART_BOT=false

# NODE_ENV: Set to 'production' for production environments.
NODE_ENV=production

# GITHUB_REPO: Repository for updates (e.g., 'user/repo').
GITHUB_REPO=""

# GITHUB_TOKEN: Personal Access Token for private repositories.
GITHUB_TOKEN=""
